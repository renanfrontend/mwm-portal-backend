# ============================================================================
# .env.dev - Desenvolvimento Local
# ============================================================================
# Este arquivo é apenas para documentação
# Não é lido automaticamente pelo Spring Boot
#
# Quando usar:
# - Desenvolvimento local em máquina
# - Banco de dados H2 em memória
# - Sem dependência de BD real
#
# Como usar:
#   ./build-dev.sh          # Compila e monta Docker
#   docker run -p 8080:8080 bioplanta-backend:dev
#
# Acessos:
#   API:        http://localhost:8080/api
#   Swagger:    http://localhost:8080/swagger-ui/index.html
#   H2 Console: http://localhost:8080/h2-console
# ============================================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Banco de Dados (H2 em memória)
SPRING_DATASOURCE_URL=jdbc:h2:mem:bioplanta-dev;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_SHOW_SQL=true

# H2 Console
SPRING_H2_CONSOLE_ENABLED=true

# Swagger
SPRINGDOC_SWAGGER_UI_ENABLED=true

# Porta
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=*
